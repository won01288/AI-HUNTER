{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    // scripts/*.mjs가 Node의 네이티브 타입 스트리핑으로 .ts 파일을 직접 실행하는데
    // (예: migrate.mjs, collect-worknet.mjs), Node ESM은 상대경로 import에
    // 확장자를 요구한다. src/lib/collectors/worknet.ts처럼 plain node에서도
    // 실행되는 파일이 "../db.ts"처럼 확장자를 붙여 import할 수 있어야 해서 켠다.
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
